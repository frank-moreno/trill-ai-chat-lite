# Files and directories to exclude from the WordPress.org SVN distribution.
# Used by deployment scripts (e.g. wp-cli/dist-archive-command).

/.git
/.github
/.DS_Store
/_proxy_fixes
/.distignore
/.gitignore
/node_modules
/tests
/phpcs.xml
/phpunit.xml
/composer.json
/composer.lock
/package.json
/package-lock.json
*.md
!readme.txt
